{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "xiaomi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Xiaomi MiMo",
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "MiMo-V2.5-Pro",
          "limit": {
            "context": 128000,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "xiaomi/mimo-v2.5-pro",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "mimo-reviewer": {
      "description": "MiMo code reviewer for RLCR loop - reviews implementation work",
      "mode": "subagent",
      "model": "xiaomi/mimo-v2.5-pro",
      "prompt": "{file:.opencode/agents/mimo-reviewer.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "grep *": "allow",
          "rg *": "allow"
        }
      }
    },
    "plan-compliance-checker": {
      "description": "Checks if a plan file is relevant to the repository",
      "mode": "subagent",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "draft-relevance-checker": {
      "description": "Checks if a draft document is relevant to the repository",
      "mode": "subagent",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "plan-understanding-quiz": {
      "description": "Generates quiz questions to verify plan understanding",
      "mode": "subagent",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "bitlesson-selector": {
      "description": "Selects relevant BitLesson entries for a sub-task",
      "mode": "subagent",
      "model": "xiaomi/mimo-v2.5-pro",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
